      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sobald ein Stuhl frei wird, geht die Einladung von selbst raus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When a chair frees up, the invitation goes out on its own."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando se libere una silla, la invitación saldrá sola."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dès qu'une chaise se libère, l'invitation part toute seule."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando una sedia si libera, l'invito parte da solo."
