    "onboarding.intro": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zwölf Stühle, fünf Zirkel, eine Glut, die wach bleiben will. Melde dich mit deinem Namen an und gründe deinen ersten Zirkel."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Twelve chairs, five circles, an ember to keep alive. Sign in with your name and found your first circle."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Doce sillas, cinco círculos, unas brasas que mantener vivas. Entra con tu nombre y funda tu primer círculo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Douze chaises, cinq cercles, une braise à garder vivante. Entre avec ton nom et fonde ton premier cercle."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodici sedie, cinque circoli, una brace da tenere viva. Entra con il tuo nome e fonda il tuo primo circolo."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Doze cadeiras, cinco círculos, uma brasa a manter acesa. Entre com seu nome e funde seu primeiro círculo."
          }
        }
      }
    },
    "onboarding.nome.conferma": {
