    "onboarding.privacy": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Name und was du teilst leben auf deinem Gerät und auf Sobremesas Server, nur damit ihr am selben Tisch sitzen könnt. Keine Werbung, kein Tracking."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your name and what you share live on your device and on Sobremesa's server, only so you can sit at the same table. No ads, no tracking."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu nombre y lo que compartes viven en tu dispositivo y en el servidor de Sobremesa, solo para sentaros a la misma mesa. Sin publicidad, sin rastreo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ton nom et ce que tu partages vivent sur ton appareil et sur le serveur de Sobremesa, seulement pour vous asseoir à la même table. Pas de pub, pas de traçage."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo nome e ciò che condividi vivono sul tuo dispositivo e sul server di Sobremesa, solo per sedervi alla stessa tavola. Niente pubblicità, niente tracciamento."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu nome e o que você compartilha vivem no seu aparelho e no servidor do Sobremesa, só para sentarem à mesma mesa. Sem anúncios, sem rastreamento."
          }
        }
      }
    },
