    "seed.comment.1": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Und das Ende im Gasthaus bleibt eines der mutigsten des Jahrhunderts."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "And the ending at the inn is still one of the bravest of the century."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Y el final en la posada sigue siendo uno de los más valientes del siglo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Et la fin à l'auberge reste l'une des plus courageuses du siècle."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "E il finale in locanda resta uno dei più coraggiosi del Novecento."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "E o final na estalagem continua sendo um dos mais corajosos do século."
          }
        }
      }
    },
    "seed.comment.2": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich bringe Popcorn mit und eine Theorie über Bergman und Schach, die ihr nicht erwartet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I'll bring popcorn and a theory about Bergman and chess you won't expect."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Llevo palomitas y una teoría sobre Bergman y el ajedrez que no os esperáis."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J'apporte le pop-corn et une théorie sur Bergman et les échecs que vous n'attendez pas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Porto i popcorn e una teoria su Bergman e gli scacchi che non vi aspettate."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Levo pipoca e uma teoria sobre Bergman e xadrez que vocês não esperam."
          }
        }
      }
    },
    "seed.comment.3": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Es enthüllt nicht, es verteidigt“ – das schreibe ich mir auf."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“It doesn't reveal, it defends”: writing that in my notebook."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«No revela, defiende»: me lo apunto en el cuaderno."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« Elle ne révèle pas, elle défend » : je le note dans mon carnet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "«Non rivela, difende»: me lo scrivo sul taccuino."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "“Não revela, defende”: vou anotar no caderno."
          }
        }
      }
    },
    "seed.comment.4": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich war am Sonntag dort: der Saal mit den Judith-Bildern ist allein die Reise wert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I went on Sunday: the room with the Judiths is worth the trip on its own."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estuve el domingo: la sala de las Judit vale el viaje por sí sola."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "J'y suis allé dimanche : la salle des Judith vaut le voyage à elle seule."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ci sono stato domenica: la sala delle Giuditte vale il viaggio da sola."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Fui no domingo: a sala das Judites vale a viagem por si só."
          }
        }
      }
    },
    "seed.comment.5": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ritual genehmigt. Ich ergänze: das Plattencover in der Hand beim Hören."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ritual approved. I'd add: hold the record sleeve while you listen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ritual aprobado. Yo añado: la funda del disco en la mano mientras se escucha."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rituel approuvé. J'ajoute : la pochette du disque entre les mains pendant l'écoute."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
