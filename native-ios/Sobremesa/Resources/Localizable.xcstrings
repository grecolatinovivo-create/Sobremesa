    "tavola.motto": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zwölf ist die richtige Zahl. Für eine neue Stimme muss eine aufstehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Twelve is the right number. For a new voice, one must stand up."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Doce es el número justo. Para una nueva voz, una debe levantarse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Douze est le bon nombre. Pour une nouvelle voix, une doit se lever."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodici è il numero giusto. Per una nuova voce, una deve alzarsi."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Doze é o número certo. Para uma nova voz, uma precisa se levantar."
          }
        }
      }
    },
