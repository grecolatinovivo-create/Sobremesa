    "tavola.candidates.empty": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch niemand zum Einladen: Die Menschen kommen, wenn Sobremesa sich der Welt öffnet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No one to invite yet: people will arrive when Sobremesa opens to the world."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todavía no hay nadie a quien invitar: la gente llegará cuando Sobremesa se abra al mundo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Personne à inviter pour l'instant : les gens arriveront quand Sobremesa s'ouvrira au monde."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non c'è ancora nessuno da invitare: le persone arriveranno quando Sobremesa si aprirà al mondo."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não há ninguém para convidar: as pessoas chegarão quando o Sobremesa se abrir ao mundo."
          }
        }
      }
    },
