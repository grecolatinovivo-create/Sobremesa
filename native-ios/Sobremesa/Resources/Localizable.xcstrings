    "notif.avviso.body": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Seit %1$lld Tagen schweigst du in „%2$@“. Ergreife wieder das Wort, bevor dein Platz frei wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You've been silent in “%2$@” for %1$lld days. Take the floor again before your seat frees up."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Llevas %1$lld días en silencio en «%2$@». Retoma la palabra antes de que tu lugar quede libre."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela fait %1$lld jours que tu te tais dans « %2$@ ». Reprends la parole avant que ta place ne se libère."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Da %1$lld giorni taci in «%2$@». Riprendi la parola prima che il posto si liberi."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Há %1$lld dias você está em silêncio em “%2$@”. Retome a palavra antes que seu lugar seja liberado."
          }
        }
      }
    },
    "notif.avviso.title": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Glut geht aus"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The embers are going out"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las brasas se están apagando"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La braise est en train de s'éteindre"
          }
        },
