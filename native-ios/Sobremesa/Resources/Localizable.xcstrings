    "tu.lingua.hint": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sobremesa spricht Italienisch, Englisch, Spanisch, Französisch, Deutsch und Portugiesisch. Standardmäßig folgt sie der Sprache des Telefons; hier wählst du selbst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sobremesa speaks Italian, English, Spanish, French, German and Portuguese. By default it follows your phone's language; here you can choose your own."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sobremesa habla italiano, inglés, español, francés, alemán y portugués. De serie sigue el idioma del teléfono; aquí puedes elegirlo tú."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sobremesa parle italien, anglais, espagnol, français, allemand et portugais. Par défaut, elle suit la langue du téléphone ; ici, c'est vous qui choisissez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sobremesa parla italiano, inglese, spagnolo, francese, tedesco e portoghese. Di serie segue la lingua del telefono; da qui puoi sceglierla tu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sobremesa fala italiano, inglês, espanhol, francês, alemão e português. Por padrão segue o idioma do telefone; aqui você pode escolher."
          }
        }
      }
    },
